# Flask Configuration
FLASK_APP=app.py
FLASK_ENV=development
SECRET_KEY=your_super_secret_session_key_here

# Database Configuration (MySQL)
# Local MySQL format: mysql+pymysql://username:password@localhost:3306/travelmate
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/travelmate

# External API Keys (Required in later phases)
GEMINI_API_KEY=your_gemini_api_key_here
OPENWEATHER_API_KEY=your_openweather_api_key_here
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here
